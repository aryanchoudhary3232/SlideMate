# Root .gitignore for Exam Slides Preparation AI

# Environment and secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.so
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.coverage
coverage.xml

# Node / Next.js
node_modules/
.next/
out/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vercel/

# Keep frontend src/lib tracked
!FRONTEND_NEXTJS/src/lib/
!FRONTEND_NEXTJS/src/lib/**

# Editors and OS
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini
